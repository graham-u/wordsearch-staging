#!/bin/bash
#
# Pre-push hook: block pushes that change user-facing files without a version bump.
#
# User-facing files: app.js, words.js, style.css, index.html, sw.js, manifest.json, icon.svg
# Version bump = the version number in both index.html and sw.js must differ between
# the remote and local endpoints.

USER_FACING="app.js words.js style.css index.html sw.js manifest.json icon.svg icon-180.png"

while read local_ref local_oid remote_ref remote_oid; do
  # Skip branch deletions
  if [ "$local_oid" = "0000000000000000000000000000000000000000" ]; then
    continue
  fi

  # Determine the range of commits being pushed
  if [ "$remote_oid" = "0000000000000000000000000000000000000000" ]; then
    # New branch — compare against main remote tracking
    range="$local_oid"
  else
    range="$remote_oid..$local_oid"
  fi

  # Get list of changed files in this push
  changed=$(git diff --name-only "$range" 2>/dev/null)
  if [ -z "$changed" ]; then
    continue
  fi

  # Check if any user-facing files changed
  user_facing_changed=false
  for f in $USER_FACING; do
    if echo "$changed" | grep -qx "$f"; then
      user_facing_changed=true
      break
    fi
  done

  if [ "$user_facing_changed" = false ]; then
    continue
  fi

  # Extract version numbers from index.html at both endpoints
  remote_html_ver=$(git show "$remote_oid:index.html" 2>/dev/null \
    | sed -n 's/.*<div id="version">v\([0-9]*\)<\/div>.*/\1/p')
  local_html_ver=$(git show "$local_oid:index.html" 2>/dev/null \
    | sed -n 's/.*<div id="version">v\([0-9]*\)<\/div>.*/\1/p')

  # Extract version numbers from sw.js at both endpoints
  remote_sw_ver=$(git show "$remote_oid:sw.js" 2>/dev/null \
    | sed -n 's/.*CACHE_NAME = "wordsearch-v\([0-9]*\)".*/\1/p')
  local_sw_ver=$(git show "$local_oid:sw.js" 2>/dev/null \
    | sed -n 's/.*CACHE_NAME = "wordsearch-v\([0-9]*\)".*/\1/p')

  # Version was bumped if both changed
  html_bumped=false
  sw_bumped=false
  [ "$local_html_ver" != "$remote_html_ver" ] && html_bumped=true
  [ "$local_sw_ver" != "$remote_sw_ver" ] && sw_bumped=true

  if [ "$html_bumped" = false ] || [ "$sw_bumped" = false ]; then
    echo ""
    echo "ERROR: User-facing files changed without a version bump."
    echo ""
    echo "Changed user-facing files:"
    for f in $USER_FACING; do
      echo "$changed" | grep -qx "$f" && echo "  - $f"
    done
    echo ""
    echo "Both index.html (version div) and sw.js (CACHE_NAME) must be updated."
    missing=""
    [ "$html_bumped" = false ] && missing="index.html "
    [ "$sw_bumped" = false ] && missing="${missing}sw.js"
    echo "Missing bump in: $missing"
    echo ""
    echo "To skip this check: git push --no-verify"
    exit 1
  fi
done

exit 0
